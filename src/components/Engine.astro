                        <div class="mini-bar" style="height: 70%;"></div>
                        <div class="mini-bar" style="height: 50%;"></div>
                        <div class="mini-bar" style="height: 65%;"></div>
                    </div>
                </div>
            </div>
            <div class="card bento-card reveal">
                <div class="bento-card-icon">
                    <svg
                        viewBox="0 0 24 24"
