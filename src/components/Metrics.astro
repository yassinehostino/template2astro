---
const { 
    label,
    m1Value, m1Unit, m1Desc,
    m2Value, m2Unit, m2Desc,
    m3Value, m3Unit, m3Desc
} = Astro.props;
---

<section class="metrics" id="metrics">
    <div class="container">
        <p class="metrics-label reveal">{label}</p>
        <div class="metrics-grid">
            <div class="metric-item reveal">
                <div class="metric-number"><span class="metric-highlight">{m1Value}</span><span class="metric-unit">{m1Unit}</span></div>
                <p class="metric-desc">{m1Desc}</p>
            </div>
            <div class="metric-item reveal">
                <div class="metric-number">{m2Value}<span class="metric-unit">{m2Unit}</span></div>
                <p class="metric-desc">{m2Desc}</p>
            </div>
            <div class="metric-item reveal">
                <div class="metric-number">{m3Value}<span class="metric-unit">{m3Unit}</span></div>
                <p class="metric-desc">{m3Desc}</p>
            </div>
        </div>
    </div>
</section>
